{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noUnusedParameters": true,
    "types": ["node"],
    "strictNullChecks": false //should fail test, don't have to workaround in ts
  }
}
